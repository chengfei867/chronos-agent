# Secrets / env
.env
.env.*
!.env.example
*.key
*.pem

# Node / TypeScript (reserved — may not apply depending on ADR-001)
node_modules/
dist/
build/
.next/
*.tsbuildinfo

# Project standardised on npm at Arc A R63 — pnpm artefacts are local-tool noise
frontend/pnpm-lock.yaml
frontend/pnpm-workspace.yaml

# Python (reserved — may not apply depending on ADR-001)
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Go (reserved)
bin/
vendor/

# Rust (reserved)
target/
Cargo.lock

# OS
.DS_Store
Thumbs.db
*.swp

# Editors
.idea/
.vscode/
*.iml

# Logs / runtime
*.log
logs/
tmp/
temp/

# Local trace data (product will generate these once code exists)
.chronos/
traces/
*.trace.jsonl

# uv / python
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
dist/
build/

# chronos-agent runtime artifacts
.chronos/
Thumbs.db
chronos.db
chronos.db-journal
chronos.db-wal
chronos.db-shm
examples/chronos.db
*.db-journal
dogfood.db
dogfood.db-shm
dogfood.db-wal

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Chronos demo DBs (regenerated by examples)
examples/chronos.db
*.db-journal

# Frontend build output is intentionally committed so pip-installed users
# get a working /app bundle without needing Node.js. See frontend/.gitignore
# for the rationale. These lines MUST be last so they win over the earlier
# generic dist/ pattern.
!frontend/dist/
!frontend/dist/**
